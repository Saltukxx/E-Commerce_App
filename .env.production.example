# Production env for docker compose (repo root)
# Copy to .env and fill secrets before deploy.

POSTGRES_PASSWORD=change_me
JWT_SECRET=change_me_minimum_32_characters_long
JWT_EXPIRES_IN=7d
ALLOW_UNPAID_ORDERS=true
CORS_ORIGINS=http://167.172.168.81,http://167.172.168.81:3001

# Web build-time URLs (browser-facing, via nginx port 80)
NEXT_PUBLIC_API_URL=http://167.172.168.81/api/v1
NEXT_PUBLIC_UPLOADS_BASE=http://167.172.168.81
REVALIDATE_SECRET=change_me_revalidate_secret

API_PORT=3001
HTTP_PORT=80

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ONBOARD_REFRESH_URL=http://167.172.168.81/admin/stripe/refresh
STRIPE_ONBOARD_RETURN_URL=http://167.172.168.81/admin/stripe/return

# Platform ledger payout: credit vendor balance on paid orders (see backend/docs/marketplace-admin.md)
PAYOUT_MODE=platform_ledger

# Absolute URLs in API responses + storefront cache bust after panel edits
PUBLIC_UPLOADS_BASE=http://167.172.168.81
PUBLIC_API_URL=http://167.172.168.81/api/v1
STOREFRONT_URL=http://167.172.168.81

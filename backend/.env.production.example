# Required: Prisma and Nest use this. Use your real production host, user, password, db name.
# Example: postgresql://USER:PASSWORD@db.example.com:5432/mydb?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

POSTGRES_PASSWORD=change_me_to_a_strong_database_password
JWT_SECRET=change_me_to_a_minimum_32_character_secret
JWT_EXPIRES_IN=7d
ALLOW_UNPAID_ORDERS=true
CORS_ORIGINS=https://durmusbaba.com,https://www.durmusbaba.com

# Stripe Connect (optional — omit to keep order-only checkout)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ONBOARD_REFRESH_URL=https://durmusbaba.com/admin/stripe/refresh
STRIPE_ONBOARD_RETURN_URL=https://durmusbaba.com/admin/stripe/return
PLATFORM_FEE_PERCENT=0
STRIPE_MULTI_VENDOR=false

# Platform ledger payout model (vendor balance + manual payout requests)
# Set to platform_ledger to credit vendor balance on paid orders instead of Stripe Connect transfers
PUBLIC_UPLOADS_BASE=http://167.172.168.81
PUBLIC_API_URL=http://167.172.168.81/api/v1
STOREFRONT_URL=http://167.172.168.81
REVALIDATE_SECRET=change_me_revalidate_secret
